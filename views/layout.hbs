<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{title}} · TaskSpace</title>
    <link rel="stylesheet" href="/stylesheets/style.css" />
  </head>
  <body class="{{bodyClass}}">
    {{#unless hideNav}}
    <header class="topbar">
      <div class="topbar-inner">
        <a href="/" class="topbar-brand">
          <svg class="brand-logo" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="16" cy="16" r="14" fill="url(#brandGrad)"/>
            <path d="M10 11.5h12M10 16h8M10 20.5h10" stroke="white" stroke-width="2" stroke-linecap="round"/>
            <defs>
              <linearGradient id="brandGrad" x1="2" y1="2" x2="30" y2="30" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="#3dd6be"/>
                <stop offset="100%" stop-color="#1589a2"/>
              </linearGradient>
            </defs>
          </svg>
          <span class="brand-name">TaskSpace</span>
        </a>
        <div class="topbar-right">
          <div class="topbar-search">
            <svg class="search-icon" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="8.5" cy="8.5" r="5.5" stroke="#94a9b5" stroke-width="1.6"/>
              <path d="M13 13l3.5 3.5" stroke="#94a9b5" stroke-width="1.6" stroke-linecap="round"/>
            </svg>
            <input type="search" class="search-input" placeholder="Search projects, tasks…" />
          </div>
          <a href="/profile" class="topbar-avatar-link">
            <div class="topbar-avatar">{{avatarInitial}}</div>
          </a>
        </div>
      </div>
    </header>
    {{/unless}}

    <main class="main-content">
      {{{body}}}
    </main>

    <script src="/javascripts/tabs.js"></script>
  </body>
</html>
