<!-- Project Hero -->
<div class="project-hero">
  <div class="project-hero-inner">
    <div class="project-hero-top">
      <div class="project-hero-left">
        <div class="project-title-row">
          <div class="project-icon">✏</div>
          <h1 class="project-title">{{project.title}}</h1>
        </div>
        <div class="project-owner-line">
          Owned by <a href="/profile">{{project.owner.username}}</a>
          &nbsp;·&nbsp; Created {{formatDate project.createdAt}}
        </div>
        {{#if project.description}}
          <p class="project-description">{{project.description}}</p>
        {{else}}
          <p class="project-description text-muted">No description provided.</p>
        {{/if}}
      </div>

      <div class="project-hero-actions">
        {{#if isStarred}}
          <form action="/project/{{project.id}}/unstar" method="POST" style="display:contents">
            <button class="btn btn-secondary btn-sm">★ Unstar</button>
          </form>
        {{else}}
          <form action="/project/{{project.id}}/star" method="POST" style="display:contents">
            <button class="btn btn-secondary btn-sm">☆ Star</button>
          </form>
        {{/if}}
        {{#if isOwner}}
          <a href="/project/{{project.id}}/edit" class="btn btn-secondary btn-sm">Edit</a>
          <form action="/project/{{project.id}}/delete" method="POST" style="display:contents"
                onsubmit="return confirm('Delete this project? This cannot be undone.')">
            <button class="btn btn-danger btn-sm">Delete</button>
          </form>
        {{/if}}
      </div>
    </div>

    <div class="project-hero-stats">
      <span class="project-hero-stat"><strong>{{memberCount}}</strong> contributor(s)</span>
      <span class="project-hero-stat"><strong>{{openTaskCount}}</strong> open task(s)</span>
      <span class="project-hero-stat"><strong>{{solutionCount}}</strong> solution(s)</span>
      <span class="project-hero-stat"><strong>{{closedTaskCount}}</strong> closed</span>
    </div>
  </div>
</div>

<!-- Project Sub-Nav -->
<div class="subnav">
  <div class="subnav-inner" data-tab-group="project">
    <button class="subnav-tab active" data-tab="tasks">
      Tasks <span class="tab-count">{{taskCount}}</span>
    </button>
    <button class="subnav-tab" data-tab="solutions">
      Solutions <span class="tab-count">{{solutionCount}}</span>
    </button>
    <button class="subnav-tab" data-tab="contributors">
      Contributors <span class="tab-count">{{memberCount}}</span>
    </button>
  </div>
</div>

<!-- Tab Panels -->
<div class="page-body">

  <!-- Tasks Tab -->
  <div class="tab-panel active" data-tab-panel="project" data-panel="tasks">
    <div class="list-toolbar">
      <div class="filter-group" data-filter-target=".task-list">
        <button class="filter-btn active" data-filter="all">All ({{taskCount}})</button>
        <button class="filter-btn" data-filter="open">Open ({{openTaskCount}})</button>
        <button class="filter-btn" data-filter="closed">Closed ({{closedTaskCount}})</button>
      </div>
      {{#if isOwner}}
        <a href="/project/{{project.id}}/task/new" class="btn btn-primary btn-sm">+ New Task</a>
      {{/if}}
    </div>

    {{#if hasTasks}}
      <div class="task-list">
        {{#each tasks}}
          <div class="task-item" data-status="{{#if isOpen}}open{{else}}closed{{/if}}">
            <div class="task-status-dot {{#if isOpen}}open{{else}}closed{{/if}}"></div>
            <div class="task-info">
              <a href="/task/{{id}}" class="task-name">{{title}}</a>
              <div class="task-meta-line">
                #{{id}} opened {{formatDate createdAt}} by {{creator.username}}
                · {{solutionCount}} solution(s)
              </div>
            </div>
            <div class="task-right">
              <span class="badge {{#if isOpen}}badge-open{{else}}badge-closed{{/if}}">
                {{#if isOpen}}Open{{else}}Closed{{/if}}
              </span>
              {{#each assignees}}
                <div class="micro-avatar {{avatarColor username}}" title="{{username}}">
                  {{initial username}}
                </div>
              {{/each}}
            </div>
          </div>
        {{/each}}
      </div>
    {{else}}
      <div class="empty-state">
        <div class="empty-state-icon">◎</div>
        <div class="empty-state-title">No tasks yet</div>
        <div class="empty-state-desc">
          {{#if isOwner}}
            <a href="/project/{{project.id}}/task/new">Create the first task</a> to get started.
          {{else}}
            Tasks will appear here once the project owner creates them.
          {{/if}}
        </div>
      </div>
    {{/if}}
  </div>

  <!-- Solutions Tab -->
  <div class="tab-panel" data-tab-panel="project" data-panel="solutions">
    <div class="list-toolbar">
      <div class="filter-group" data-filter-target=".solution-list">
        <button class="filter-btn active" data-filter="all">All ({{solutionCount}})</button>
        <button class="filter-btn" data-filter="pending">Pending</button>
        <button class="filter-btn" data-filter="approved">Approved</button>
        <button class="filter-btn" data-filter="rejected">Rejected</button>
      </div>
    </div>

    {{#if hasSolutions}}
      <div class="solution-list">
        {{#each solutions}}
          <div class="solution-item" data-status="{{status}}">
            <div class="solution-item-dot {{#if isApproved}}approved{{else}}{{#if isRejected}}rejected{{else}}pending{{/if}}{{/if}}"></div>
            <div class="solution-item-info">
              <a href="/solution/{{id}}" class="solution-item-name">{{title}}</a>
              <div class="solution-item-meta">
                By <strong>{{submittedBy.username}}</strong> · {{formatDate createdAt}}
                &nbsp;·&nbsp;
                <a href="/task/{{task.id}}" class="solution-item-task-link">→ {{task.title}}</a>
                <span class="badge {{#if isApproved}}badge-approved{{else}}{{#if isRejected}}badge-rejected{{else}}badge-pending{{/if}}{{/if}}">
                  {{status}}
                </span>
              </div>
            </div>
          </div>
        {{/each}}
      </div>
    {{else}}
      <div class="empty-state">
        <div class="empty-state-icon">◈</div>
        <div class="empty-state-title">No solutions yet</div>
        <div class="empty-state-desc">Solutions will appear here once contributors submit them to open tasks.</div>
      </div>
    {{/if}}
  </div>

  <!-- Contributors Tab -->
  <div class="tab-panel" data-tab-panel="project" data-panel="contributors">

    {{#if isOwner}}
      <div class="invite-section">
        {{#if inviteError}}
          <div class="invite-error">{{inviteError}}</div>
        {{/if}}
        <form action="/project/{{project.id}}/invite" method="POST" class="invite-form">
          <input type="text" name="username" class="form-input invite-input"
                 placeholder="Invite by username…" autocomplete="off" required />
          <button type="submit" class="btn btn-primary btn-sm">Invite</button>
        </form>
      </div>
    {{/if}}

    {{#if hasContributors}}
      <div class="contrib-toolbar">
        <span class="contrib-period-label">Activity period:</span>
        <div class="contrib-toggle" id="contrib-toggle">
          <button class="contrib-toggle-btn active" data-period="daily">30 Days</button>
          <button class="contrib-toggle-btn" data-period="weekly">8 Weeks</button>
        </div>
      </div>
      <div class="contributors-list">
        {{#each contributors}}
          <div class="contributor-card">
            <div class="contributor-row">
              <span class="contributor-rank {{#eq rank 1}}r1{{/eq}}{{#eq rank 2}}r2{{/eq}}{{#eq rank 3}}r3{{/eq}}">
                {{rank}}
              </span>
              <div class="contributor-avatar {{avatarColor username}}">{{initial username}}</div>
              <div class="contributor-info">
                <div class="contributor-name">{{username}}</div>
              </div>
              <div class="contributor-bar-track">
                <div class="contributor-bar-fill" style="width:{{barPercent}}%"></div>
              </div>
              <div class="contributor-count">{{count}} <span>contributions</span></div>
              {{#if ../isOwner}}
                {{#unless isProjectOwner}}
                  <form action="/project/{{../project.id}}/remove-member" method="POST" style="display:contents"
                        onsubmit="return confirm('Remove {{username}} from this project?')">
                    <input type="hidden" name="userId" value="{{userId}}" />
                    <button class="btn btn-danger btn-sm">Remove</button>
                  </form>
                {{/unless}}
              {{/if}}
            </div>
            <div class="contributor-chart-wrap">
              <canvas class="contributor-chart"
                      data-daily-values='{{{chartDailyData}}}'
                      data-weekly-values='{{{chartWeeklyData}}}'></canvas>
            </div>
          </div>
        {{/each}}
      </div>
    {{else}}
      <div class="empty-state">
        <div class="empty-state-icon">◉</div>
        <div class="empty-state-title">No contributors yet</div>
        <div class="empty-state-desc">Invite collaborators above to get started.</div>
      </div>
    {{/if}}
  </div>

</div>
