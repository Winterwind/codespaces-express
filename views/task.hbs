<div class="detail-wrap">

  <!-- Breadcrumb -->
  <nav class="breadcrumb">
    <a href="/profile">Profile</a>
    <span class="breadcrumb-sep">/</span>
    <a href="/project/{{task.project.id}}">{{task.project.title}}</a>
    <span class="breadcrumb-sep">/</span>
    <a href="/project/{{task.project.id}}">Tasks</a>
    <span class="breadcrumb-sep">/</span>
    <span>#{{task.id}}</span>
  </nav>

  <!-- Title Row -->
  <div class="detail-title-row">
    <h1 class="detail-title">{{task.title}}</h1>
    <span class="badge {{#if isOpen}}badge-open{{else}}badge-closed{{/if}}">
      {{#if isOpen}}Open{{else}}Closed{{/if}}
    </span>
  </div>
  <div class="detail-meta-line">
    Task <strong>#{{task.id}}</strong> opened <strong>{{formatDate task.createdAt}}</strong>
    by <a href="/profile">{{task.creator.username}}</a>
    &nbsp;·&nbsp; {{solutionCount}} solution{{#gt solutionCount 1}}s{{/gt}}
  </div>

  <!-- Main Layout -->
  <div class="detail-layout">

    <!-- Body + Solutions -->
    <div>
      <div class="detail-body">
        <div class="detail-body-header">
          <span><strong>{{task.creator.username}}</strong> described this task</span>
          <span>{{formatDate task.createdAt}}</span>
        </div>
        <div class="detail-body-content">
          {{#if task.description}}
            {{task.description}}
          {{else}}
            <span class="text-muted">No description provided.</span>
          {{/if}}
        </div>
      </div>

      <!-- Solutions -->
      <div class="subsection">
        <div class="subsection-title">Solutions ({{solutionCount}})</div>

        {{#if hasSolutions}}
          {{#each solutions}}
            <div class="linked-solution-item">
              <div style="width:12px;height:12px;border-radius:50%;flex-shrink:0;
                background:{{#if isApproved}}var(--green){{else}}#e0b030{{/if}};
                box-shadow:0 1px 4px rgba(0,0,0,.15);"></div>
              <div class="linked-solution-info">
                <a href="/solution/{{id}}" class="linked-solution-name">{{title}}</a>
                <div class="linked-solution-meta">
                  By {{submittedBy.username}} · {{formatDate createdAt}}
                </div>
              </div>
              <span class="badge {{#if isApproved}}badge-approved{{else}}badge-pending{{/if}}">
                {{status}}
              </span>
            </div>
          {{/each}}
        {{else}}
          <div class="empty-state" style="padding:28px 0;">
            <div class="empty-state-icon">◈</div>
            <div class="empty-state-title">No solutions yet</div>
            <div class="empty-state-desc">Be the first to submit a solution to this task.</div>
          </div>
        {{/if}}

        {{#if isOpen}}
          <a href="/solution/new?taskId={{task.id}}&projectId={{task.project.id}}"
             class="btn btn-outline btn-sm" style="margin-top:10px;">
            + Submit a Solution
          </a>
        {{/if}}
      </div>
    </div>

    <!-- Sidebar -->
    <div class="detail-sidebar">

      <div class="sidebar-box">
        <div class="sidebar-box-title">Assignees</div>
        <div class="sidebar-box-body">
          {{#if task.assignees.length}}
            {{#each task.assignees}}
              <div class="assignee-row">
                <div class="micro-avatar {{avatarColor username}}">{{initial username}}</div>
                {{username}}
              </div>
            {{/each}}
          {{else}}
            <span class="text-muted text-sm">No assignees.</span>
          {{/if}}
        </div>
      </div>

      <div class="sidebar-box">
        <div class="sidebar-box-title">Status</div>
        <div class="sidebar-box-body">
          <span class="badge {{#if isOpen}}badge-open{{else}}badge-closed{{/if}}"
                style="margin-bottom:10px;display:inline-flex;">
            {{#if isOpen}}Open{{else}}Closed{{/if}}
          </span>
          {{#if isOwner}}
            <br/>
            {{#if isOpen}}
              <form action="/task/{{task.id}}/close" method="POST" style="display:contents">
                <button class="btn btn-secondary btn-sm btn-block" style="margin-top:6px;">
                  Close Task
                </button>
              </form>
            {{else}}
              <form action="/task/{{task.id}}/reopen" method="POST" style="display:contents">
                <button class="btn btn-secondary btn-sm btn-block" style="margin-top:6px;">
                  Reopen Task
                </button>
              </form>
            {{/if}}
          {{/if}}
        </div>
      </div>

      <div class="sidebar-box">
        <div class="sidebar-box-title">Project</div>
        <div class="sidebar-box-body">
          <a href="/project/{{task.project.id}}" style="font-size:13px;font-weight:600;">
            {{task.project.title}}
          </a>
        </div>
      </div>

    </div>
  </div>

</div>
