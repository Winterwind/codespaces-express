<!-- Profile Header -->
<div class="profile-header">
  <div class="profile-header-inner">
    <div class="profile-user-row">
      <div class="profile-avatar">{{initial profileUser.username}}</div>

      <div class="profile-details">
        <div class="profile-name">{{profileUser.username}}</div>
        <div class="profile-username">@{{profileUser.username}}</div>
        {{#if profileUser.bio}}
          <div class="profile-bio">{{profileUser.bio}}</div>
        {{/if}}
        <div class="profile-meta">
          <span class="profile-meta-item">
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
              <rect x="2" y="3" width="12" height="11" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
              <path d="M2 7h12M5 2v2M11 2v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            Joined {{formatDate profileUser.createdAt}}
          </span>
        </div>
      </div>

      <div class="profile-stats">
        <div class="stat-box">
          <div class="stat-value">{{projectCount}}</div>
          <div class="stat-label">Projects</div>
        </div>
        <div class="stat-box">
          <div class="stat-value">{{contributionCount}}</div>
          <div class="stat-label">Contributions</div>
        </div>
        <div class="stat-box">
          <div class="stat-value">{{starCount}}</div>
          <div class="stat-label">Stars</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Tab Nav -->
  <div class="subnav">
    <div class="subnav-inner" data-tab-group="profile">
      <button class="subnav-tab active" data-tab="overview">Overview</button>
      <button class="subnav-tab" data-tab="projects">
        Projects <span class="tab-count">{{projectCount}}</span>
      </button>
      <button class="subnav-tab" data-tab="stars">
        Stars <span class="tab-count">{{starCount}}</span>
      </button>
    </div>
  </div>
</div>

<!-- Tab Panels -->
<div class="page-body">

  <!-- Overview -->
  <div class="tab-panel active" data-tab-panel="profile" data-panel="overview">
    {{#if pinnedProjects.length}}
      <p class="text-sm text-muted" style="margin-bottom:14px;">Created Projects</p>
      <div class="pinned-grid">
        {{#each pinnedProjects}}
          <div class="project-card">
            <div class="project-card-main">
              <a href="/project/{{id}}" class="project-card-name">{{title}}</a>
              <div class="project-card-desc">
                {{#if description}}{{description}}{{else}}No description.{{/if}}
              </div>
              <div class="project-card-footer">
                <span class="project-card-stat">
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none">
                    <circle cx="8" cy="5" r="3" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M2 14c0-3.31 2.69-6 6-6s6 2.69 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                  {{memberCount}} contributor{{#gt memberCount 1}}s{{/gt}}
                </span>
                <span class="project-card-stat">Updated {{formatDate updatedAt}}</span>
              </div>
            </div>
          </div>
        {{/each}}
      </div>
    {{else}}
      <div class="empty-state" style="padding-top:32px;">
        <div class="empty-state-icon">◎</div>
        <div class="empty-state-title">No projects yet</div>
        <div class="empty-state-desc">
          <a href="/project/new">Create your first project</a> to get started.
        </div>
      </div>
    {{/if}}

    <!-- Activity Heatmap -->
    <div class="heatmap-section">
      <div class="heatmap-label">{{contributionCount}} contributions in the last year</div>
      <div class="heatmap-grid"><!-- filled by tabs.js --></div>
      <div class="heatmap-legend">
        Less
        <div class="legend-cell" style="background:var(--border-light)"></div>
        <div class="legend-cell" style="background:#b4e3dc"></div>
        <div class="legend-cell" style="background:#75ccbf"></div>
        <div class="legend-cell" style="background:#35b5a4"></div>
        <div class="legend-cell" style="background:var(--teal)"></div>
        More
      </div>
    </div>
  </div>

  <!-- Projects -->
  <div class="tab-panel" data-tab-panel="profile" data-panel="projects">
    <div class="flex-between" style="margin-bottom:16px;">
      <span class="text-sm text-muted">{{projectCount}} project{{#gt projectCount 1}}s{{/gt}}</span>
      <a href="/project/new" class="btn btn-primary btn-sm">+ New Project</a>
    </div>

    {{#if projects.length}}
      <div class="project-list">
        {{#each projects}}
          <div class="project-card">
            <div class="project-card-main">
              <a href="/project/{{id}}" class="project-card-name">{{title}}</a>
              <div class="project-card-desc">
                {{#if description}}{{description}}{{else}}No description.{{/if}}
              </div>
              <div class="project-card-footer">
                <span class="badge badge-open">Open</span>
                <span class="project-card-stat">{{memberCount}} contributor{{#gt memberCount 1}}s{{/gt}}</span>
                <span class="project-card-stat">Updated {{formatDate updatedAt}}</span>
              </div>
            </div>
          </div>
        {{/each}}
      </div>
    {{else}}
      <div class="empty-state">
        <div class="empty-state-icon">◎</div>
        <div class="empty-state-title">No projects yet</div>
        <div class="empty-state-desc">
          <a href="/project/new">Create your first project</a> to get started.
        </div>
      </div>
    {{/if}}
  </div>

  <!-- Stars -->
  <div class="tab-panel" data-tab-panel="profile" data-panel="stars">
    {{#if starredProjects.length}}
      <p class="text-sm text-muted" style="margin-bottom:16px;">Projects you've starred</p>
      <div class="stars-grid">
        {{#each starredProjects}}
          <div class="project-card">
            <div class="project-card-main">
              <div style="font-size:11px;color:var(--text-muted);margin-bottom:4px;">
                {{owner.username}} /
              </div>
              <a href="/project/{{id}}" class="project-card-name">{{title}}</a>
              <div class="project-card-desc">
                {{#if description}}{{description}}{{else}}No description.{{/if}}
              </div>
              <div class="project-card-footer">
                <span class="project-card-stat">★ Starred</span>
              </div>
            </div>
          </div>
        {{/each}}
      </div>
    {{else}}
      <div class="empty-state">
        <div class="empty-state-icon">☆</div>
        <div class="empty-state-title">No starred projects</div>
        <div class="empty-state-desc">Projects you star will appear here.</div>
      </div>
    {{/if}}
  </div>

</div>
