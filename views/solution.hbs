<div class="detail-wrap">

  <!-- Breadcrumb -->
  <nav class="breadcrumb">
    <a href="/profile">Profile</a>
    <span class="breadcrumb-sep">/</span>
    <a href="/project/{{solution.project.id}}">{{solution.project.title}}</a>
    <span class="breadcrumb-sep">/</span>
    <a href="/project/{{solution.project.id}}">Solutions</a>
    <span class="breadcrumb-sep">/</span>
    <span>#{{solution.id}}</span>
  </nav>

  <!-- Title Row -->
  <div class="detail-title-row">
    <h1 class="detail-title">{{solution.title}}</h1>
    {{#if isApproved}}
      <span class="badge badge-approved">Approved</span>
    {{else}}
      {{#if isRejected}}
        <span class="badge badge-rejected">Rejected</span>
      {{else}}
        <span class="badge badge-pending">Pending</span>
      {{/if}}
    {{/if}}
  </div>
  <div class="detail-meta-line">
    Solution <strong>#{{solution.id}}</strong> submitted <strong>{{formatDate solution.createdAt}}</strong>
    by <a href="/profile">{{solution.submittedBy.username}}</a>
    &nbsp;·&nbsp; for task <a href="/task/{{solution.task.id}}">#{{solution.task.id}} — {{solution.task.title}}</a>
  </div>

  <!-- Main Layout -->
  <div class="detail-layout">

    <!-- Body + Files + Actions -->
    <div>
      <div class="detail-body">
        <div class="detail-body-header">
          <span><strong>{{solution.submittedBy.username}}</strong> described this solution</span>
          <span>{{formatDate solution.createdAt}}</span>
        </div>
        <div class="detail-body-content">
          {{#if solution.description}}
            {{solution.description}}
          {{else}}
            <span class="text-muted">No description provided.</span>
          {{/if}}
        </div>
      </div>

      <!-- File Attachments -->
      <div class="subsection">
        <div class="subsection-title">Attachments ({{solution.files.length}})</div>
        {{#if hasFiles}}
          <div class="file-list">
            {{#each solution.files}}
              <div class="file-item">
                <div class="file-icon fi-doc">FILE</div>
                <span>{{originalName}}</span>
                <span class="file-size">{{size}} bytes</span>
              </div>
            {{/each}}
          </div>
        {{else}}
          <p class="text-muted text-sm" style="padding:4px 0;">
            No files attached. File upload support is coming soon.
          </p>
        {{/if}}
      </div>

      <!-- Approve / Reject -->
      {{#if isOwner}}
        {{#if isPending}}
          <div class="solution-actions">
            <p class="solution-actions-note">
              Approving this solution will close task
              <a href="/task/{{solution.task.id}}">#{{solution.task.id}}</a>.
            </p>
            <form action="/solution/{{solution.id}}/approve" method="POST" style="display:contents">
              <button class="btn btn-approve btn-sm">✓ Approve</button>
            </form>
            <form action="/solution/{{solution.id}}/reject" method="POST" style="display:contents"
                  onsubmit="return confirm('Reject this solution?')">
              <button class="btn btn-danger btn-sm">✕ Reject</button>
            </form>
          </div>
        {{/if}}
        {{#if isApproved}}
          <div class="solution-actions">
            <p class="solution-actions-note">This solution has been approved and its task is now closed.</p>
          </div>
        {{/if}}
        {{#if isRejected}}
          <div class="solution-actions">
            <p class="solution-actions-note">This solution has been rejected.</p>
          </div>
        {{/if}}
      {{/if}}
    </div>

    <!-- Sidebar -->
    <div class="detail-sidebar">

      <div class="sidebar-box">
        <div class="sidebar-box-title">Submitted By</div>
        <div class="sidebar-box-body">
          <div class="assignee-row">
            <div class="micro-avatar {{avatarColor solution.submittedBy.username}}">
              {{initial solution.submittedBy.username}}
            </div>
            {{solution.submittedBy.username}}
          </div>
        </div>
      </div>

      <div class="sidebar-box">
        <div class="sidebar-box-title">Linked Task</div>
        <div class="sidebar-box-body">
          <a href="/task/{{solution.task.id}}" style="font-size:13px;font-weight:600;">
            #{{solution.task.id}} — {{solution.task.title}}
          </a>
          <div style="margin-top:6px;">
            {{#if (eq solution.task.status "open")}}
              <span class="badge badge-open">Open</span>
            {{else}}
              <span class="badge badge-closed">Closed</span>
            {{/if}}
          </div>
        </div>
      </div>

      <div class="sidebar-box">
        <div class="sidebar-box-title">Status</div>
        <div class="sidebar-box-body">
          {{#if isApproved}}
            <span class="badge badge-approved" style="display:inline-flex;">Approved</span>
          {{else}}
            {{#if isRejected}}
              <span class="badge badge-rejected" style="display:inline-flex;">Rejected</span>
            {{else}}
              <span class="badge badge-pending" style="display:inline-flex;">Pending Review</span>
            {{/if}}
          {{/if}}
        </div>
      </div>

      <div class="sidebar-box">
        <div class="sidebar-box-title">Project</div>
        <div class="sidebar-box-body">
          <a href="/project/{{solution.project.id}}" style="font-size:13px;font-weight:600;">
            {{solution.project.title}}
          </a>
        </div>
      </div>

    </div>
  </div>

</div>
